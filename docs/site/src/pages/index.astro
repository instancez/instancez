---
// Custom landing page — uses no Starlight layout; standalone HTML
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>instancez — Self-hosted Supabase-compatible backend</title>
<meta name="description" content="A self-hosted Supabase-compatible backend. Define your schema in YAML, get a full Postgres API with auth, RLS, functions, and storage.">
<link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #080808; color: #e8e8e8; min-height: 100vh; }

  nav { display: flex; align-items: center; justify-content: space-between; padding: 18px 48px; border-bottom: 1px solid #232323; position: sticky; top: 0; background: #080808cc; backdrop-filter: blur(8px); z-index: 10; }
  .nav-logo { display: flex; align-items: center; gap: 10px; font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; color: #fff; text-decoration: none; }
  .nav-logo img { width: 28px; height: 28px; }
  .nav-links { display: flex; gap: 28px; font-size: 0.875rem; color: #999; }
  .nav-links a { color: inherit; text-decoration: none; }
  .nav-links a:hover { color: #e8e8e8; }
  .nav-cta { background: #fff; color: #080808; font-size: 0.875rem; font-weight: 700; padding: 8px 18px; border-radius: 6px; text-decoration: none; }

  .hero { text-align: center; padding: 100px 24px 84px; max-width: 760px; margin: 0 auto; }
  .hero-badge { display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #aaa; border: 1px solid #2e2e2e; padding: 5px 14px; border-radius: 99px; margin-bottom: 28px; }
  .hero h1 { font-size: 3.5rem; font-weight: 800; letter-spacing: -0.05em; line-height: 1.05; color: #fff; margin-bottom: 22px; }
  .hero p { font-size: 1.1rem; color: #bbb; line-height: 1.75; margin-bottom: 44px; max-width: 520px; margin-left: auto; margin-right: auto; }
  .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 52px; }
  .btn-primary { background: #fff; color: #080808; font-weight: 700; padding: 13px 28px; border-radius: 8px; text-decoration: none; font-size: 0.95rem; }
  .btn-secondary { color: #aaa; font-weight: 600; padding: 13px 20px; border-radius: 8px; text-decoration: none; font-size: 0.95rem; border: 1px solid #2e2e2e; }

  .install-wrap { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .install-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #777; }
  .install-tabs { display: flex; gap: 2px; background: #151515; border: 1px solid #242424; border-radius: 8px; padding: 3px; }
  .install-tab { font-size: 0.72rem; font-weight: 600; color: #666; background: transparent; border: none; padding: 5px 14px; border-radius: 6px; cursor: pointer; transition: color 0.15s, background 0.15s; }
  .install-tab.active { background: #242424; color: #e8e8e8; }
  .install-block { display: inline-flex; align-items: center; gap: 14px; background: #101010; border: 1px solid #2a2a2a; border-radius: 10px; padding: 14px 22px; font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.9rem; }
  .install-block .prompt { color: #555; user-select: none; }
  .install-block .cmd { color: #fff; }
  .install-cmd { display: none; width: 100%; }
  .install-cmd.active { display: flex; }
  .install-note { font-size: 0.75rem; color: #555; }

  .divider { border: none; border-top: 1px solid #181818; margin: 0; }

  .features { padding: 72px 48px; max-width: 1080px; margin: 0 auto; }
  .features-header { text-align: center; margin-bottom: 52px; }
  .features-header h2 { font-size: 2rem; font-weight: 700; letter-spacing: -0.04em; color: #fff; margin-bottom: 12px; }
  .features-header p { color: #bbb; font-size: 0.95rem; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #1e1e1e; border: 1px solid #1e1e1e; border-radius: 12px; overflow: hidden; }
  .feature-card { background: #080808; padding: 28px; }
  .feature-icon { font-size: 1.25rem; margin-bottom: 14px; }
  .feature-card h3 { font-size: 0.95rem; font-weight: 700; color: #f0f0f0; margin-bottom: 8px; }
  .feature-card p { font-size: 0.83rem; color: #999; line-height: 1.65; }
  .feature-card code { background: #141414; padding: 1px 5px; border-radius: 3px; font-size: 0.8em; color: #ddd; font-family: 'SF Mono', 'Fira Code', monospace; border: 1px solid #252525; }

  /* CODE BLOCKS — syntax highlighted */
  .demo { padding: 72px 48px; max-width: 980px; margin: 0 auto; }
  .demo h2 { font-size: 1.875rem; font-weight: 700; letter-spacing: -0.04em; color: #fff; margin-bottom: 8px; text-align: center; }
  .demo .sub { color: #aaa; text-align: center; margin-bottom: 40px; font-size: 0.95rem; }
  .demo-split { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #222; border: 1px solid #222; border-radius: 14px; overflow: hidden; }
  .code-block { background: #111; }
  .code-block-header { padding: 11px 18px; border-bottom: 1px solid #1e1e1e; font-size: 0.7rem; font-weight: 700; color: #888; letter-spacing: 0.08em; text-transform: uppercase; display: flex; align-items: center; gap: 10px; background: #0e0e0e; }
  .dot { width: 9px; height: 9px; border-radius: 50%; }
  .code-block pre { padding: 24px 22px; font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace; font-size: 0.8rem; line-height: 1.9; white-space: pre; }

  /* Syntax token colors — proper editor palette */
  .k  { color: #c792ea; }              /* keyword: const, await, true, false */
  .fn { color: #82aaff; }              /* function / method call */
  .s  { color: #c3e88d; }              /* string */
  .n  { color: #f78c6c; }              /* number / boolean */
  .cm { color: #546e7a; font-style: italic; } /* comment */
  .p  { color: #89ddff; }              /* punctuation / operator */
  .yk { color: #89ddff; }              /* YAML key */
  .yv { color: #c3e88d; }              /* YAML string value */
  .yb { color: #f78c6c; }              /* YAML boolean */
  .plain { color: #cdd3de; }           /* default / identifiers */

  .cta-strip { margin: 0 auto 80px; max-width: 860px; padding: 0 48px; }
  .cta-inner { border: 1px solid #232323; border-radius: 14px; padding: 56px 40px; text-align: center; background: #0c0c0c; }
  .cta-inner h2 { font-size: 2.25rem; font-weight: 800; letter-spacing: -0.04em; color: #fff; margin-bottom: 12px; }
  .cta-inner p { color: #aaa; margin-bottom: 32px; font-size: 0.95rem; }

  footer { border-top: 1px solid #181818; padding: 24px 48px; text-align: center; font-size: 0.78rem; color: #666; }
</style>
</head>
<body>

<nav>
  <a href={`${base}/`} class="nav-logo">
    <img src={`${base}/favicon.svg`} alt="instancez" />
    instancez
  </a>
  <div class="nav-links">
    <a href={`${base}/quick-start/`}>Quick Start</a>
    <a href={`${base}/build/schema/`}>Build</a>
    <a href={`${base}/deploy/docker/`}>Deploy</a>
    <a href={`${base}/api-reference/rest/`}>API Reference</a>
  </div>
  <a href={`${base}/quick-start/`} class="nav-cta">Get Started →</a>
</nav>

<section class="hero">
  <div class="hero-badge">Supabase-compatible · Open Source · MIT</div>
  <h1>Your backend.<br>Your infrastructure.</h1>
  <p>A self-hosted Supabase-compatible backend. Define your schema in YAML and get a full Postgres-backed API with auth, RLS, functions, and storage — up and running in minutes.</p>
  <div class="hero-actions">
    <a href={`${base}/quick-start/`} class="btn-primary">Quick Start →</a>
    <a href="https://github.com/instancez/instancez" class="btn-secondary">View on GitHub ↗</a>
  </div>
  <div class="install-wrap">
    <div class="install-label">Install</div>
    <div class="install-tabs">
      <button class="install-tab active" data-os="mac">macOS</button>
      <button class="install-tab" data-os="linux">Linux</button>
      <button class="install-tab" data-os="windows">Windows</button>
    </div>
    <div class="install-cmd active" id="cmd-mac">
      <div class="install-block">
        <span class="prompt">$</span>
        <span class="cmd">curl -fsSL https://get.instancez.io | sh</span>
      </div>
    </div>
    <div class="install-cmd" id="cmd-linux">
      <div class="install-block">
        <span class="prompt">$</span>
        <span class="cmd">curl -fsSL https://get.instancez.io | sh</span>
      </div>
    </div>
    <div class="install-cmd" id="cmd-windows">
      <div class="install-block">
        <span class="prompt">PS&gt;</span>
        <span class="cmd">irm https://get.instancez.io/windows | iex</span>
      </div>
    </div>
    <a href={`${base}/install/`} class="install-note">All install options →</a>
  </div>

  <script>
    const tabs = document.querySelectorAll('.install-tab');
    const cmds = document.querySelectorAll('.install-cmd');
    function activate(os: string) {
      tabs.forEach(t => t.classList.toggle('active', (t as HTMLElement).dataset.os === os));
      cmds.forEach(c => c.classList.toggle('active', c.id === `cmd-${os}`));
    }
    tabs.forEach(tab => tab.addEventListener('click', () => activate((tab as HTMLElement).dataset.os!)));
    // Auto-detect OS
    const ua = navigator.userAgent;
    if (/Windows/i.test(ua)) activate('windows');
    else if (/Linux/i.test(ua)) activate('linux');
    else activate('mac');
  </script>
</section>

<hr class="divider">

<section class="features">
  <div class="features-header">
    <h2>What you need. Nothing extra.</h2>
    <p>Wire-compatible with <code style="background:#111;padding:2px 7px;border-radius:4px;font-size:0.85em;color:#ddd;border:1px solid #252525;font-family:'SF Mono','Fira Code',monospace">@supabase/supabase-js</code> — drop it in, no client changes required.</p>
  </div>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">🗂</div>
      <h3>YAML-driven schema</h3>
      <p>Define tables, fields, types, and RLS policies in <code>instancez.yaml</code>. In dev mode, saves trigger migrations automatically.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔐</div>
      <h3>Auth that works</h3>
      <p>Password, magic link, OTP, OAuth (Google, GitHub), anonymous sign-in, and TOTP MFA. All tied directly into Postgres RLS.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">⚡</div>
      <h3>PostgREST-compatible API</h3>
      <p>Full filtering, embeds, aggregates, pagination, and RPC. The same query surface your supabase-js code already knows.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🧩</div>
      <h3>Code functions</h3>
      <p>JavaScript ESM handlers at <code>/functions/v1/&lt;name&gt;</code>. Each handler gets <code>ctx.supabase</code>, secrets, and structured logging.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🗄</div>
      <h3>Storage</h3>
      <p>File upload and download with local or S3 backends. Bucket policies run through RLS — same model as everything else.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🚀</div>
      <h3>Deploy anywhere</h3>
      <p>Single binary. Docker, AWS Lambda, bare metal — one command to run, one YAML file to configure.</p>
    </div>
  </div>
</section>

<hr class="divider">

<section class="demo">
  <h2>Write YAML. Ship an API.</h2>
  <p class="sub">One file for schema and RLS. instancez handles the rest.</p>
  <div class="demo-split">
    <div class="code-block">
      <div class="code-block-header">
        <div class="dot" style="background:#ff5f57"></div>
        <div class="dot" style="background:#febc2e"></div>
        <div class="dot" style="background:#28c840"></div>
        instancez.yaml
      </div>
      <pre><span class="yk">tables</span><span class="p">:</span>
  <span class="yk">posts</span><span class="p">:</span>
    <span class="yk">fields</span><span class="p">:</span>
      <span class="p">-</span> <span class="yk">name</span><span class="p">:</span> <span class="yv">id</span>
        <span class="yk">type</span><span class="p">:</span> <span class="yv">bigserial</span>
        <span class="yk">primary_key</span><span class="p">:</span> <span class="yb">true</span>
      <span class="p">-</span> <span class="yk">name</span><span class="p">:</span> <span class="yv">title</span>
        <span class="yk">type</span><span class="p">:</span> <span class="yv">text</span>
        <span class="yk">required</span><span class="p">:</span> <span class="yb">true</span>
      <span class="p">-</span> <span class="yk">name</span><span class="p">:</span> <span class="yv">user_id</span>
        <span class="yk">type</span><span class="p">:</span> <span class="yv">uuid</span>
        <span class="yk">foreign_key</span><span class="p">:</span>
          <span class="yk">references</span><span class="p">:</span> <span class="yv">auth.users.id</span>
    <span class="yk">rls</span><span class="p">:</span>
      <span class="p">-</span> <span class="yk">operations</span><span class="p">:</span> [<span class="yv">select</span>]
        <span class="yk">check</span><span class="p">:</span> <span class="s">"true"</span>
      <span class="p">-</span> <span class="yk">operations</span><span class="p">:</span> [<span class="yv">insert</span><span class="p">,</span> <span class="yv">update</span><span class="p">,</span> <span class="yv">delete</span>]
        <span class="yk">check</span><span class="p">:</span> <span class="s">"auth.uid() = user_id"</span></pre>
    </div>
    <div class="code-block">
      <div class="code-block-header">
        <div class="dot" style="background:#ff5f57"></div>
        <div class="dot" style="background:#febc2e"></div>
        <div class="dot" style="background:#28c840"></div>
        Your Frontend
      </div>
      <pre><span class="cm">// @supabase/supabase-js, unchanged</span>
<span class="k">const</span> <span class="plain">supabase</span> <span class="p">=</span> <span class="fn">createClient</span><span class="p">(</span>
  <span class="s">'http://localhost:8080'</span><span class="p">,</span>
  <span class="s">'your-anon-key'</span>
<span class="p">)</span>

<span class="cm">// query</span>
<span class="k">const</span> <span class="p">{</span> <span class="plain">data</span> <span class="p">}</span> <span class="p">=</span> <span class="k">await</span> <span class="plain">supabase</span>
  <span class="p">.</span><span class="fn">from</span><span class="p">(</span><span class="s">'posts'</span><span class="p">)</span>
  <span class="p">.</span><span class="fn">select</span><span class="p">(</span><span class="s">'id, title'</span><span class="p">)</span>
  <span class="p">.</span><span class="fn">order</span><span class="p">(</span><span class="s">'id'</span><span class="p">,</span> <span class="p">{</span> <span class="plain">ascending</span><span class="p">:</span> <span class="k">false</span> <span class="p">})</span>

<span class="cm">// insert — RLS enforces user_id automatically</span>
<span class="k">const</span> <span class="p">{</span> <span class="plain">data</span> <span class="p">}</span> <span class="p">=</span> <span class="k">await</span> <span class="plain">supabase</span>
  <span class="p">.</span><span class="fn">from</span><span class="p">(</span><span class="s">'posts'</span><span class="p">)</span>
  <span class="p">.</span><span class="fn">insert</span><span class="p">({</span> <span class="plain">title</span><span class="p">:</span> <span class="s">'Hello world'</span> <span class="p">})</span>
  <span class="p">.</span><span class="fn">select</span><span class="p">()</span>
  <span class="p">.</span><span class="fn">single</span><span class="p">()</span></pre>
    </div>
  </div>
</section>

<div class="cta-strip">
  <div class="cta-inner">
    <h2>Ready to build?</h2>
    <p>One command to install. One YAML file to start. Running in minutes.</p>
    <a href={`${base}/quick-start/`} class="btn-primary">Get started →</a>
  </div>
</div>

<footer>instancez · open source · MIT license</footer>

</body>
</html>
