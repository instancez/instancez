---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
import type { Props } from '@astrojs/starlight/props';
import { execSync } from 'child_process';

// CI sets DOCS_VERSION to the release tag. Fall back to `git describe` locally.
let version: string | null = import.meta.env.DOCS_VERSION ?? null;
if (!version) {
  try {
    version = execSync('git describe --tags --abbrev=0 2>/dev/null', { encoding: 'utf8' }).trim() || null;
  } catch {}
}
---

<Default {...Astro.props}><slot /></Default>
{version && (
  <a
    href={`https://github.com/instancez/instancez/releases/tag/${version}`}
    class="version-badge"
    target="_blank"
    rel="noopener noreferrer"
  >
    {version}
  </a>
)}

<style>
  .version-badge {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #555;
    border: 1px solid #2a2a2a;
    border-radius: 99px;
    padding: 2px 9px;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
    margin-left: 0.25rem;
  }
  .version-badge:hover {
    color: #bbb;
    border-color: #444;
  }
</style>
