---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
import type { Props } from '@astrojs/starlight/props';
import { execSync } from 'child_process';

let version: string | null = import.meta.env.DOCS_VERSION ?? null;
if (!version) {
  try {
    version = execSync('git describe --tags --abbrev=0 2>/dev/null', { encoding: 'utf8' }).trim() || null;
  } catch {}
}
---

<Default {...Astro.props}><slot /></Default>

{version && (
  <script define:vars={{ version, releaseUrl: `https://github.com/instancez/instancez/releases/tag/${version}` }}>
    // Insert the badge after the site-title anchor, outside the title-wrapper,
    // so it doesn't affect the header grid column sizing.
    document.addEventListener('DOMContentLoaded', () => {
      const titleWrapper = document.querySelector('.title-wrapper');
      if (!titleWrapper || document.querySelector('.version-badge')) return;

      const badge = document.createElement('a');
      badge.href = releaseUrl;
      badge.textContent = version;
      badge.className = 'version-badge';
      badge.target = '_blank';
      badge.rel = 'noopener noreferrer';

      // Insert after the title-wrapper, inside the header grid row
      titleWrapper.parentElement.insertBefore(badge, titleWrapper.nextSibling);
    });
  </script>
)}

<style is:global>
  .version-badge {
    display: inline-flex;
    align-items: center;
    align-self: center;
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #555;
    border: 1px solid #2a2a2a;
    border-radius: 99px;
    padding: 2px 9px;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
    margin-left: 0.75rem;
  }
  .version-badge:hover {
    color: #bbb;
    border-color: #444;
  }
</style>
